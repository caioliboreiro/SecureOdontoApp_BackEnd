# Application
NODE_ENV=dev
PORT=3333

DATABASE_URL="postgresql://docker:docker@localhost:5432/odonto-app?schema=public"

# Auth
JWT_SECRET=

# Error tracking
SENTRY_DSN=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# HTTPS (local development only)
HTTPS_ENABLED=false
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key
